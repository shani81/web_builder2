# ── BUILDR API environment ──────────────────────────────────────────────
# Copy to `apps/api/.env` and fill in. The server validates these on boot.

# Runtime
NODE_ENV=development
PORT=4001
# Dual-stack bind (IPv4 + IPv6). So `localhost` reaches the API on either.
HOST=::

# Auth secrets — MUST be at least 32 characters each in production.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-32+-character-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-32+-char-string

# AI (Phase 5). Without a key, AI endpoints are disabled.
ANTHROPIC_API_KEY=sk-ant-...

# Media (Phase 7). Unsplash stock photo search.
UNSPLASH_ACCESS_KEY=

# Pixabay stock photos (platform-wide key). Get one at
# https://pixabay.com/api/docs/ — without it, the Stock Photos tab is disabled.
PIXABAY_API_KEY=

# CORS — comma-separate multiple origins.
CORS_ORIGIN=http://localhost:3000

# JSON file store location (relative to apps/api).
DATA_DIR=./data

# Public base URL of this API (used to build absolute media URLs).
PUBLIC_URL=http://localhost:4001
