# ── BUILDR Web environment ──────────────────────────────────────────────
# Copy to `apps/web/.env.local`. Only NEXT_PUBLIC_* vars reach the browser.

# Base URL of the BUILDR API (includes the /api/v1 prefix).
NEXT_PUBLIC_API_URL=http://localhost:4001/api/v1

# Public URL of this web app (used for canonical/OG tags).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
